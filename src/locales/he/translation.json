    "features": [
      "\u05e9\u05d9\u05e2\u05d5\u05e8\u05d9\u05dd \u05e4\u05e8\u05d8\u05e0\u05d9\u05d9\u05dd",
      "\u05dc\u05d5\u05d7 \u05d6\u05de\u05e0\u05d9\u05dd \u05d2\u05de\u05d9\u05e9 \u05d0\u05d5\u05e0\u05dc\u05d9\u05d9\u05df",
      "\u05d7\u05d5\u05de\u05e8\u05d9\u05dd \u05de\u05e7\u05d5\u05e8\u05d9\u05d9\u05dd"
    ],
    "form": {
