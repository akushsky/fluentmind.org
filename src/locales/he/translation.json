  "courses": {
    "title": "\u05d4\u05e7\u05d5\u05e8\u05e1\u05d9\u05dd \u05e9\u05dc\u05e0\u05d5",
    "subtitle": "\u05d1\u05d7\u05e8\u05d5 \u05d0\u05ea \u05e4\u05d5\u05e8\u05de\u05d8 \u05d4\u05dc\u05de\u05d9\u05d3\u05d4 \u05d4\u05de\u05ea\u05d0\u05d9\u05dd",
    "description": "\u05d0\u05e0\u05d5 \u05de\u05e6\u05d9\u05e2\u05d9\u05dd \u05e4\u05d5\u05e8\u05de\u05d8\u05d9\u05dd \u05e9\u05d5\u05e0\u05d9\u05dd \u05e9\u05dc \u05dc\u05de\u05d9\u05d3\u05d4, \u05de\u05d5\u05ea\u05d0\u05de\u05d9\u05dd \u05dc\u05e6\u05e8\u05db\u05d9\u05dd \u05d5\u05dc\u05de\u05d0\u05e4\u05d9\u05d9\u05e0\u05d9 \u05d4\u05ea\u05e4\u05d9\u05e1\u05d4 \u05e9\u05dc\u05db\u05dd.",
    "items": [
      {
        "title": "\u05e9\u05d9\u05e2\u05d5\u05e8\u05d9\u05dd \u05e4\u05e8\u05d8\u05e0\u05d9\u05d9\u05dd",
        "subtitle": "\u05d2\u05d9\u05e9\u05d4 \u05d0\u05d9\u05e9\u05d9\u05ea",
        "description": "\u05e9\u05d9\u05e2\u05d5\u05e8\u05d9\u05dd \u05d0\u05d9\u05e9\u05d9\u05d9\u05dd \u05d0\u05d7\u05d3 \u05e2\u05dc \u05d0\u05d7\u05d3 \u05e2\u05dd \u05de\u05d5\u05e8\u05d4. \u05ea\u05d5\u05db\u05e0\u05d9\u05ea \u05de\u05d5\u05ea\u05d0\u05de\u05ea \u05d1\u05de\u05dc\u05d5\u05d0\u05d4 \u05dc\u05de\u05d8\u05e8\u05d5\u05ea \u05d5\u05dc\u05e6\u05e8\u05db\u05d9\u05dd \u05e9\u05dc\u05db\u05dd.",
        "features": [
          "\u05dc\u05d5\u05d7 \u05d6\u05de\u05e0\u05d9\u05dd \u05d2\u05de\u05d9\u05e9",
          "\u05ea\u05d5\u05db\u05e0\u05d9\u05ea \u05d0\u05d9\u05e9\u05d9\u05ea",
          "\u05de\u05e7\u05e1\u05d9\u05de\u05d5\u05dd \u05ea\u05e9\u05d5\u05de\u05ea \u05dc\u05d1",
          "\u05d4\u05ea\u05e7\u05d3\u05de\u05d5\u05ea \u05de\u05d4\u05d9\u05e8\u05d4"
        ],
        "cta": "\u05d4\u05e8\u05e9\u05de\u05d5"
      },
      {
        "title": "\u05de\u05d9\u05e0\u05d9-\u05e7\u05d1\u05d5\u05e6\u05d5\u05ea",
        "subtitle": "\u05dc\u05de\u05d9\u05d3\u05d4 \u05d1\u05e7\u05d1\u05d5\u05e6\u05d5\u05ea \u05e7\u05d8\u05e0\u05d5\u05ea",
        "description": "\u05e9\u05d9\u05e2\u05d5\u05e8\u05d9\u05dd \u05d1\u05e7\u05d1\u05d5\u05e6\u05d5\u05ea \u05e7\u05d8\u05e0\u05d5\u05ea \u05e9\u05dc \u05e2\u05d3 4 \u05d0\u05e0\u05e9\u05d9\u05dd. \u05d0\u05d9\u05d6\u05d5\u05df \u05d1\u05d9\u05df \u05d2\u05d9\u05e9\u05d4 \u05d0\u05d9\u05e9\u05d9\u05ea \u05dc\u05d3\u05d9\u05e0\u05de\u05d9\u05e7\u05d4 \u05e7\u05d1\u05d5\u05e6\u05ea\u05d9\u05ea.",
        "features": [
          "\u05e7\u05d1\u05d5\u05e6\u05d5\u05ea \u05e9\u05dc \u05e2\u05d3 4 \u05d0\u05e0\u05e9\u05d9\u05dd",
          "\u05dc\u05de\u05d9\u05d3\u05d4 \u05d0\u05d9\u05e0\u05d8\u05e8\u05d0\u05e7\u05d8\u05d9\u05d1\u05d9\u05ea",
          "\u05ea\u05de\u05d9\u05db\u05ea \u05e7\u05d1\u05d5\u05e6\u05d4",
          "\u05de\u05d7\u05d9\u05e8 \u05e0\u05d2\u05d9\u05e9"
        ],
        "cta": "\u05d4\u05e8\u05e9\u05de\u05d5"
      },
      {
        "title": "\u05ea\u05d5\u05db\u05e0\u05d9\u05d5\u05ea \u05de\u05ea\u05de\u05d7\u05d5\u05ea",
        "subtitle": "\u05dc\u05e6\u05e8\u05db\u05d9\u05dd \u05de\u05d9\u05d5\u05d7\u05d3\u05d9\u05dd",
        "description": "\u05ea\u05d5\u05db\u05e0\u05d9\u05d5\u05ea \u05dc\u05d0\u05e0\u05e9\u05d9\u05dd \u05e2\u05dd \u05de\u05d0\u05e4\u05d9\u05d9\u05e0\u05d9 \u05d4\u05ea\u05e4\u05ea\u05d7\u05d5\u05ea \u05d5\u05e0\u05d5\u05d9\u05e8\u05d5-\u05e9\u05d5\u05e0\u05d5\u05ea. \u05d2\u05d9\u05e9\u05d4 \u05e0\u05d5\u05d9\u05e8\u05d5-\u05d9\u05d3\u05d9\u05d3\u05d5\u05ea\u05d9\u05ea \u05dc\u05dc\u05de\u05d9\u05d3\u05d4.",
        "features": [
          "\u05d2\u05d9\u05e9\u05d4 \u05e0\u05d5\u05d9\u05e8\u05d5-\u05d9\u05d3\u05d9\u05d3\u05d5\u05ea\u05d9\u05ea",
          "\u05d7\u05d5\u05de\u05e8\u05d9\u05dd \u05de\u05d5\u05ea\u05d0\u05de\u05d9\u05dd",
          "\u05ea\u05de\u05d9\u05db\u05ea \u05de\u05d5\u05de\u05d7\u05d9\u05dd",
          "\u05e1\u05d1\u05d9\u05d1\u05d4 \u05e0\u05d5\u05d7\u05d4"
        ],
        "cta": "\u05dc\u05de\u05d3 \u05e2\u05d5\u05d3"
      }
    ]
  },
  "careers": {
    "title": "\u05e7\u05e8\u05d9\u05d9\u05e8\u05d4 \u05d1-Fluent Mind",
    "subtitle": "\u05d4\u05e6\u05d8\u05e8\u05e4\u05d5 \u05dc\u05e6\u05d5\u05d5\u05ea \u05e9\u05dc\u05e0\u05d5",
    "description": "\u05d0\u05e0\u05d5 \u05de\u05d7\u05e4\u05e9\u05d9\u05dd \u05de\u05d5\u05e8\u05d9\u05dd \u05de\u05d5\u05db\u05e9\u05e8\u05d9\u05dd \u05e9\u05d7\u05d5\u05dc\u05e7\u05d9\u05dd \u05d0\u05ea \u05d4\u05d2\u05d9\u05e9\u05d4 \u05e9\u05dc\u05e0\u05d5 \u05dc\u05d7\u05d9\u05e0\u05d5\u05da \u05e0\u05d5\u05d9\u05e8\u05d5-\u05d9\u05d3\u05d9\u05d3\u05d5\u05ea\u05d9. \u05d0\u05dd \u05d0\u05ea\u05dd \u05e0\u05dc\u05d4\u05d1\u05d9\u05dd \u05de\u05e9\u05e4\u05d5\u05ea \u05d5\u05e8\u05d5\u05e6\u05d9\u05dd \u05dc\u05e2\u05d6\u05d5\u05e8 \u05dc\u05d0\u05e0\u05e9\u05d9\u05dd \u05dc\u05d4\u05e9\u05d9\u05d2 \u05d0\u05ea \u05de\u05d8\u05e8\u05d5\u05ea\u05d9\u05d4\u05dd, \u05e0\u05e9\u05de\u05d7 \u05dc\u05d4\u05db\u05d9\u05e8 \u05d0\u05ea\u05db\u05dd.",
    "benefits": {
      "title": "\u05de\u05d4 \u05d0\u05e0\u05d7\u05e0\u05d5 \u05de\u05e6\u05d9\u05e2\u05d9\u05dd",
      "items": [
        "\u05dc\u05d5\u05d7 \u05d6\u05de\u05e0\u05d9\u05dd \u05d2\u05de\u05d9\u05e9",
        "\u05e2\u05d1\u05d5\u05d3\u05d4 \u05de\u05e8\u05d7\u05d5\u05e7",
        "\u05ea\u05de\u05d9\u05db\u05d4 \u05d5\u05d4\u05db\u05e9\u05e8\u05d4",
        "\u05e9\u05db\u05e8 \u05ea\u05d7\u05e8\u05d5\u05ea\u05d9",
        "\u05e2\u05d1\u05d5\u05d3\u05d4 \u05e2\u05dd \u05ea\u05dc\u05de\u05d9\u05d3\u05d9\u05dd \u05de\u05e2\u05e0\u05d9\u05d9\u05e0\u05d9\u05dd",
        "\u05d0\u05e4\u05e9\u05e8\u05d5\u05ea \u05dc\u05e6\u05de\u05d9\u05d7\u05d4 \u05de\u05e7\u05e6\u05d5\u05e2\u05d9\u05ea"
      ]
    },
